generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String
  techStack   String   // Stored as comma-separated or JSON string
  tags        String   // Stored as comma-separated
  status      String   // Idea, Building, Shipped, Paused
  links       String?  // Optional links (JSON or comma-separated)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries     Entry[]
  resources   Resource[]
}

model Entry {
  id        String   @id @default(cuid())
  title     String
  date      DateTime @default(now())
  notes     String   // Markdown content
  tags      String   // Stored as comma-separated
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  resources Resource[] @relation("EntryResources")
}

model Resource {
  id        String   @id @default(cuid())
  url       String
  title     String
  category  String
  notes     String?
  tags      String   // Stored as comma-separated
  isRead    Boolean  @default(false)
  isFavorite Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  entries   Entry[] @relation("EntryResources")
}
